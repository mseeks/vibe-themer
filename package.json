{
  "name": "vibe-themer",
  "displayName": "Vibe Themer",
  "description": "🎨 AI-powered VS Code theme generator. Describe your vibe and watch a complete theme stream in live, generated by OpenAI or Anthropic models.",
  "version": "2.1.0",
  "publisher": "mseeks",
  "license": "MIT",
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mseeks/vibe-themer"
  },
  "homepage": "https://github.com/mseeks/vibe-themer#readme",
  "bugs": {
    "url": "https://github.com/mseeks/vibe-themer/issues"
  },
  "sponsor": {
    "url": "https://github.com/sponsors/mseeks"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "activationEvents": [
    "onCommand:vibeThemer.changeTheme",
    "onCommand:vibeThemer.clearApiKey",
    "onCommand:vibeThemer.resetTheme",
    "onCommand:vibeThemer.selectModel",
    "onCommand:vibeThemer.resetModel"
  ],
  "categories": [
    "Themes",
    "Other"
  ],
  "keywords": [
    "theme",
    "color",
    "ai",
    "openai",
    "anthropic",
    "claude",
    "gpt",
    "customization"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vibeThemer.changeTheme",
        "title": "Vibe Themer: Change Theme"
      },
      {
        "command": "vibeThemer.clearApiKey",
        "title": "Vibe Themer: Clear API Keys"
      },
      {
        "command": "vibeThemer.resetTheme",
        "title": "Vibe Themer: Reset Theme Customizations"
      },
      {
        "command": "vibeThemer.selectModel",
        "title": "Vibe Themer: Select Model"
      },
      {
        "command": "vibeThemer.resetModel",
        "title": "Vibe Themer: Reset Model Selection"
      }
    ],
    "configuration": {
      "title": "Vibe Themer",
      "properties": {
        "vibeThemer.applyTo": {
          "type": "string",
          "enum": [
            "global",
            "workspace"
          ],
          "enumDescriptions": [
            "User (global) settings — the theme follows you across all windows.",
            "The current workspace's settings — falls back to global if no folder is open."
          ],
          "default": "global",
          "description": "Where Vibe Themer writes generated theme customizations."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "package": "npm run check-types && npm run lint && node ./esbuild.js --production",
    "compile": "npm run check-types && npm run lint && node ./esbuild.js",
    "check-types": "tsc --noEmit",
    "watch": "npm run check-types && node ./esbuild.js --watch",
    "lint": "eslint src test --ext ts",
    "test": "node ./esbuild.test.js && node out/test.cjs"
  },
  "devDependencies": {
    "@types/node": "^20.17.58",
    "@types/vscode": "^1.74.0",
    "@typescript-eslint/eslint-plugin": "^7.7.1",
    "@typescript-eslint/parser": "^7.7.1",
    "esbuild": "^0.28.1",
    "eslint": "^8.57.0",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.102.0",
    "openai": "^6.42.0"
  }
}
